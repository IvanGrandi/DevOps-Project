Vagrant.configure("2") do |config|
  # Use the official Ubuntu 22.04 LTS image
  config.vm.box = "ubuntu/jammy64"
  
  # Network configuration
  # Access Jenkins at http://localhost:8082
  config.vm.network "forwarded_port", guest: 8080, host: 8082, id: "jenkins"
  config.vm.network "private_network", ip: "192.168.56.20"

  # Syncs the local 'jenkins-lab' folder to the VM
  config.vm.synced_folder "./jenkins", "/home/vagrant/lab", create: true

  config.vm.provider "virtualbox" do |vb|
    vb.gui = false
    vb.memory = 2048
    vb.cpus = 2
  end

  # Provisioning script to install Java, .NET, and Jenkins
  config.vm.provision "shell", inline: <<-SHELL
    echo "Updating system packages..."
    sudo apt-get update -y

    echo "Installing Java (Jenkins requires Java)..."
    sudo apt-get install -y fontconfig openjdk-21-jre
        
    echo "Installing .NET 10..."
    curl -sSL https://dot.net/v1/dotnet-install.sh | bash /dev/stdin --channel 10.0 --install-dir /usr/share/dotnet

    echo "Adding Jenkins repository keys..."
    sudo wget -O /usr/share/keyrings/jenkins-keyring.asc \
      https://pkg.jenkins.io/debian-stable/jenkins.io-2026.key
    echo "deb [signed-by=/usr/share/keyrings/jenkins-keyring.asc]" \
      https://pkg.jenkins.io/debian-stable binary/ | sudo tee \
      /etc/apt/sources.list.d/jenkins.list > /dev/null

    echo "Installing Jenkins..."
    sudo apt-get update -y
    sudo apt-get install -y jenkins

    echo "======================================================="
    echo "Jenkins installation complete!"
    echo "Wait a minute for it to start, then go to: http://localhost:8082"
    echo "Your initial unlock password is:"
    sudo cat /var/lib/jenkins/secrets/initialAdminPassword
    echo "======================================================="
  SHELL
end